{
  "name": "weatherbot-ts",
  "version": "1.0.0",
  "description": "Polymarket weather trading bot with Kelly Criterion, Stop Loss, SQLite, and Dashboard",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "signal": "npm run build && node dist/index.js",
    "paper": "npm run build && node dist/index.js --paper"
    "execute": "npm run build && node dist/index.js --execute",
    "trade": "npm run build && node dist/index.js --execute --interval 30",
    "positions": "npm run build && node dist/index.js --positions",
    "reset": "npm run build && node dist/index.js --reset",
    "db-reset": "npm run build && node dist/index.js --db-reset",
    "dashboard": "ts-node dashboard/server.ts"
  },
  "dependencies": {
    "@polymarket/clob-client": "^5.5.0",
    "@ethersproject/wallet": "^5.7.0",
    "axios": "^1.6.0",
    "better-sqlite3": "^9.0.0",
    "chalk": "^4.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.0",
    "socket.io": "^4.5.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.8.10",
    "@types/socket.io": "^3.0.2",
    "@types/yargs": "^17.0.29"
  }
}

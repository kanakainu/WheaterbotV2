{
  "name": "weatherbot-ts",
  "version": "1.0.0",
  "description": "TypeScript fork of the Weather Trading Bot for Polymarket.",
  "main": "dist/index.js",
  "scripts": {
  "build": "tsc",
  "signal": "npm run build && node dist/index.js",
  "paper": "npm run build && node dist/index.js --live",
  "execute": "npm run build && node dist/index.js --execute",
  "trade": "npm run build && node dist/index.js --execute --interval 30",
  "positions": "npm run build && node dist/index.js --positions",
  "reset": "npm run build && node dist/index.js --reset",
  "db-reset": "npm run build && node dist/index.js --db-reset",
  "dashboard": "ts-node dashboard/server.ts",
  "dashboard-build": "tsc dashboard/server.ts --outDir dist/dashboard"
 },
  "keywords": [
    "weather",
    "polymarket",
    "trading",
    "bot",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ethersproject/wallet": "^5.8.0",
    "@polymarket/clob-client": "^4.22.8",
    "axios": "^1.7.7",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/node": "^22.10.0",
    "@types/yargs": "^17.0.32",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
    "axios": "^1.6.0",
  "express": "^4.18.0",
  "socket.io": "^4.5.0",
  "cors": "^2.8.5",
  "better-sqlite3": "^9.0.0"
  }
}
